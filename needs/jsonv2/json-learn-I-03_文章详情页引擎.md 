## 3. UI 事件绑定说明

### 搜索筛选（列表页）

```javascript
// Fuse.js 初始化
var articleData = []; // 从 DOM 或内联 JSON 获取文章数据
var fuse = new Fuse(articleData, {
  keys: [
    { name: 'title', weight: 0.4 },
    { name: 'titleEN', weight: 0.3 },
    { name: 'summary', weight: 0.2 },
    { name: 'category', weight: 0.1 },
  ],
  threshold: 0.3,
  includeMatches: true,
});

// 筛选状态
var filterState = {
  category: 'all',
  level: 'all',
  query: '',
};

function applyFilters() {
  var cards = document.querySelectorAll('.article-card');
  var results = filterState.query
    ? fuse.search(filterState.query).map(r => r.item.slug)
    : null;

  var visibleCount = 0;
  cards.forEach(function(card, index) {
    var matchCategory = filterState.category === 'all' || card.dataset.category === filterState.category;
    var matchLevel = filterState.level === 'all' || card.dataset.level === filterState.level;
    var matchSearch = !results || results.includes(card.dataset.slug);

    if (matchCategory && matchLevel && matchSearch) {
      card.style.display = '';
      card.style.animationDelay = (visibleCount * 50) + 'ms';
      visibleCount++;
    } else {
      card.style.display = 'none';
    }
  });

  // 空状态
  document.getElementById('articlesEmpty').style.display = visibleCount === 0 ? '' : 'none';
}
```

### 分类标签点击

```javascript
document.querySelectorAll('[data-filter]').forEach(function(btn) {
  btn.addEventListener('click', function() {
    // 移除同组 active
    this.parentElement.querySelectorAll('.filter-tag').forEach(function(t) {
      t.classList.remove('filter-tag--active');
    });
    this.classList.add('filter-tag--active');
    filterState.category = this.dataset.filter;
    applyFilters();
  });
});
```

### TOC 滚动高亮（文章详情页）

```javascript
// IntersectionObserver 回调
function onHeadingIntersect(entries) {
  entries.forEach(function(entry) {
    if (entry.isIntersecting) {
      // 移除所有高亮
      document.querySelectorAll('.toc-link').forEach(function(link) {
        link.classList.remove('toc-link--active');
      });
      // 高亮当前
      var tocLink = document.querySelector('.toc-link[href="#' + entry.target.id + '"]');
      if (tocLink) {
        tocLink.classList.add('toc-link--active');
        // 确保 TOC 容器内可见
        tocLink.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
      }
    }
  });
}
```

### FAQ 手风琴

```javascript
function toggleFAQ(button) {
  var faqItem = button.closest('.faq-item');
  var answer = faqItem.querySelector('.faq-item__answer');
  var isOpen = button.getAttribute('aria-expanded') === 'true';

  // 关闭所有其他
  document.querySelectorAll('.faq-item').forEach(function(item) {
    if (item !== faqItem) {
      item.querySelector('.faq-item__question').setAttribute('aria-expanded', 'false');
      item.querySelector('.faq-item__answer').style.maxHeight = '0';
      item.classList.remove('faq-item--open');
    }
  });

  // 切换当前
  if (isOpen) {
    button.setAttribute('aria-expanded', 'false');
    answer.style.maxHeight = '0';
    faqItem.classList.remove('faq-item--open');
  } else {
    button.setAttribute('aria-expanded', 'true');
    answer.style.maxHeight = answer.scrollHeight + 'px';
    faqItem.classList.add('faq-item--open');
  }
}
```

